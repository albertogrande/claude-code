---
import { getCollection, render } from 'astro:content';
import ReadingLayout from '../../layouts/ReadingLayout.astro';
import { withBase, fmtLong } from '../../lib/site';

export async function getStaticPaths() {
  const radar = await getCollection('radar');
  return radar.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<ReadingLayout title={d.title} description={d.summary} deskLabel="Radar" stamp={fmtLong(d.date)}>
  <div class="entry-lead" slot="lead">
    <span class="kind">{d.kind}</span>
    {d.tags.length > 0 && (
      <ul class="tags">
        {d.tags.map((t) => (
          <li><span class="tag">{t}</span></li>
        ))}
      </ul>
    )}
  </div>

  <Content />

  {d.take && (
    <div class="note-box take">
      <p class="note-k">The take</p>
      <p>{d.take}</p>
    </div>
  )}

  <Fragment slot="foot">
    {d.related.length > 0 && (
      <p class="related">
        <span class="related-k">Related</span>
        {d.related.map((r, i) => (
          <Fragment>
            {i > 0 && <span class="sep" aria-hidden="true">·</span>}
            <a href={r.href.startsWith('http') ? r.href : withBase(r.href)}>{r.label}</a>
          </Fragment>
        ))}
      </p>
    )}
    {d.sources.length > 0 && (
      <div class="sources">
        <p class="sources-h">Source{d.sources.length > 1 ? 's' : ''} — check it yourself</p>
        <ol>
          {d.sources.map((s) => (
            <li>
              <span class="amber" aria-hidden="true">→</span>
              <a href={s.url} rel="noopener">{s.label}</a>
            </li>
          ))}
        </ol>
      </div>
    )}
    <nav class="section-nav">
      <a href={withBase('/radar')}>← all updates</a>
      <span class="spacer"></span>
      <a href={withBase('/guide')}>the guide →</a>
    </nav>
  </Fragment>
</ReadingLayout>
