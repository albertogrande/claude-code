---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import { withBase, isoDate } from '../../lib/site';
import { getDivesSorted } from '../../lib/content';

const dives = await getDivesSorted();
---
<BaseLayout
  title="Deep dives"
  description="Long-form, researched deep dives on Claude Code — models, workflows, and the decisions worth getting right. Each one sourced."
>
  <div class="page-head">
    <div class="kicker"><span class="prompt" aria-hidden="true">&gt;</span> deep dives</div>
    <h1 class="page-title">Deep dives</h1>
    <p class="dek">
      Longer, researched pieces — one subject taken all the way down. Where the
      guide is a reference and the week is the pulse, these are the deep cuts,
      each sourced back to the docs and the community.
    </p>
  </div>

  {dives.length > 0 ? (
    <ul class="ar-list">
      {dives.map((d) => (
        <li class="ar-row">
          <span class="ar-date">{isoDate(d.data.date)}</span>
          <div class="ar-main">
            <div class="ar-head">
              <span class="kind">deep dive</span>
              <a href={withBase(`/deep-dives/${d.id}`)} class="ar-title">{d.data.title}</a>
            </div>
            <span class="ar-meta">{d.data.summary}</span>
            <TagList tags={d.data.tags} style="margin-top:8px" />
          </div>
        </li>
      ))}
    </ul>
  ) : (
    <p class="dek">The first dive is in the works. Check back shortly.</p>
  )}
</BaseLayout>
