---
import { getCollection, render } from 'astro:content';
import ReadingLayout from '../../layouts/ReadingLayout.astro';
import ArticleFoot from '../../components/ArticleFoot.astro';
import TagList from '../../components/TagList.astro';
import { fmtLong } from '../../lib/site';

export async function getStaticPaths() {
  const dives = await getCollection('deep-dives');
  return dives.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;
---
<ReadingLayout
  title={d.title}
  description={d.summary}
  deskLabel="Deep dive"
  stamp={fmtLong(d.date)}
  published={d.date}
  updated={d.updated}
>
  <div class="entry-lead" slot="lead">
    {d.dek && <p class="dek" style="margin-top:14px">{d.dek}</p>}
    <TagList tags={d.tags} style="margin-top:14px" />
  </div>

  <Content />

  <ArticleFoot
    slot="foot"
    updated={d.updated}
    related={d.related}
    sources={d.sources}
    backHref="/deep-dives"
    backLabel="all deep dives"
    forwardHref="/guide"
    forwardLabel="the guide"
  />
</ReadingLayout>
