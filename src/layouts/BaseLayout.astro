---
import '../styles/main.scss';
import Head from '../components/Head.astro';
import Chrome from '../components/Chrome.astro';
import Footer from '../components/Footer.astro';
import Shortcuts from '../components/Shortcuts.astro';

interface Props {
  title: string;
  description?: string;
  home?: boolean; // Front page: narrow mono chrome + full-bleed body
  type?: 'website' | 'article';
  published?: Date;
  updated?: Date;
}
const { title, description, home = false, type, published, updated } = Astro.props;
---
<!doctype html>
<html lang="en">
  <Head title={title} description={description} type={type} published={published} updated={updated} />
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Chrome wide={home} />
    {
      home ? (
        <main id="main"><slot /></main>
      ) : (
        <main class="page" id="main"><slot /></main>
      )
    }
    <Footer />
    <Shortcuts />
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var root = document.documentElement;
        function sync() {
          var dark = root.getAttribute('data-theme') === 'dark';
          btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
        }
        sync();
        btn.addEventListener('click', function () {
          var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          root.setAttribute('data-theme', next);
          try {
            localStorage.setItem('sota-theme', next);
          } catch (e) {}
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', next === 'dark' ? '#0d1117' : '#fbfaf8');
          sync();
        });
      })();
    </script>
  </body>
</html>
